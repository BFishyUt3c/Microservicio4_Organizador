# CONFIGURACIÓN DEL MICROSERVICIO 4

# URLs de los Microservicios
MS1_URL=http://ms1-usuarios:8000
MS2_URL=http://ms2-peliculas:3000
MS3_URL=http://ms3-foro:8080

# Timeout para las peticiones HTTP (en segundos)
TIMEOUT=10

# Configuración del Puerto
PORT=8004

# Modo de Logging
LOG_LEVEL=INFO

# IMPORTANTE:
# Para desarrollo local, reemplaza las URLs con:
# MS1_URL=http://localhost:8000
# MS2_URL=http://localhost:3000
# MS3_URL=http://localhost:8080
# 
# Para Docker Compose, usa los nombres de los servicios:
# MS1_URL=http://ms1-usuarios:8000
# MS2_URL=http://ms2-peliculas:3000
# MS3_URL=http://ms3-foro:8080
